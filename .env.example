# ──────────────────────────────────────────────────────────────────────────────
# Lognis — environment variable template (monorepo root)
# Copy this file to .env and fill in your values.
# docker-compose.yml reads this file via env_file: .env
# ──────────────────────────────────────────────────────────────────────────────

# ── Backend: Application ──────────────────────────────────────────────────────
APP_NAME=Lognis
APP_VERSION=0.1.0
DEBUG=false

# ── Backend: Server ───────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8080

# ── Backend: Security  ← change before deploying ─────────────────────────────
SECRET_KEY=change-me-in-production
API_KEY_HEADER=X-API-Key
API_KEY=dev-api-key

# ── Backend: RapidAPI proxy secret  ← must be set in production ───────────────
# Leave empty to disable enforcement during local development.
RAPIDAPI_PROXY_SECRET=

# ── Backend: CORS ─────────────────────────────────────────────────────────────
# JSON array of allowed origins. Never use "*" with credentialed requests.
ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:3000"]

# ── Backend: Database (Neon Postgres or any Postgres 14+) ─────────────────────
# docker-compose.yml overrides this to point at the local `db` container.
# Set this to your Neon connection string for production / CI.
DATABASE_URL=postgresql+asyncpg://user:pass@host/dbname?sslmode=require

# ── Backend: Redis ────────────────────────────────────────────────────────────
# docker-compose.yml overrides this to point at the local `redis` container.
# Set this to your production Redis URL for Railway / Upstash / etc.
REDIS_URL=redis://redis.railway.internal:6379

# ── Local Postgres container (docker-compose only) ────────────────────────────
# Only used when running `make dev`; has no effect in production.
POSTGRES_USER=lognis
POSTGRES_PASSWORD=lognis
POSTGRES_DB=lognis

# ── Frontend: Clerk ───────────────────────────────────────────────────────────
# Copy the values from your Clerk dashboard.
# These are also needed in apps/frontend/.env.local for local Next.js dev
# outside of Docker.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Frontend: API URL ─────────────────────────────────────────────────────────
# In Docker dev the browser talks to the forwarded backend port on the host.
# Override with your deployed API URL for production builds.
NEXT_PUBLIC_API_URL=http://localhost:8080
